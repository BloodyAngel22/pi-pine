{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pi Pine",
  "version": "0.1.0",
  "identifier": "dev.pipine.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "DeveloperTool",
    "shortDescription": "Компактный десктоп-клиент для pi",
    "longDescription": "Минималистичный десктоп-фронтенд к pi (pi.dev). Использует pi --mode rpc как бэкенд.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "librsvg2-2"]
      }
    }
  }
}
