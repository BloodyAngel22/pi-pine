{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Pi Pine default capability set",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:webview:allow-set-webview-zoom",
    "core:event:default",
    "core:path:default",
    "shell:default",
    "shell:allow-open",
    "fs:default",
    "fs:allow-home-read",
    "fs:allow-home-read-recursive",
    "dialog:default",
    "dialog:allow-open",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-read-image"
  ]
}